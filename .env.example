# Server bind
PORT=4173
HOST=127.0.0.1

# API auth token (recommended for any non-localhost exposure)
OPENCLAW_DASH_TOKEN=replace-with-strong-token

# Rate limiting (requests per minute per IP)
RATE_LIMIT_MAX=60

# Request timeout (ms)
REQUEST_TIMEOUT_MS=120000

# Source routing
OPENCLAW_INCLUDE_LOCAL_SOURCE=1
OPENCLAW_DEFAULT_SOURCE=local
REMOTE_FETCH_TIMEOUT_MS=15000

# Multi-source example:
# OPENCLAW_INCLUDE_LOCAL_SOURCE=0
# OPENCLAW_DEFAULT_SOURCE=office
# OFFICE_REMOTE_TOKEN=replace-with-strong-token
# OPENCLAW_REMOTE_SOURCES=[{"id":"office","label":"Office Mac","url":"http://127.0.0.1:74173/api/telemetry","tokenEnv":"OFFICE_REMOTE_TOKEN","timeoutMs":12000}]
# RECONNECT_DELAY_SEC=3
# SSH_CONNECT_TIMEOUT_SEC=10
# SSH_SERVER_ALIVE_INTERVAL=10
# SSH_SERVER_ALIVE_COUNT_MAX=3
